{
  "name": "openkei",
  "displayName": "OpenKei",
  "description": "OpenKei VS Code extension for OpenCode",
  "version": "1.0.2",
  "publisher": "keindl29",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/keibn29/openkei.git"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Programming Languages",
    "Machine Learning",
    "Other"
  ],
  "keywords": [
    "ai",
    "claude",
    "gpt",
    "agent",
    "coding",
    "chatgpt",
    "groq",
    "assistant",
    "opencode",
    "openkei"
  ],
  "icon": "assets/app-icon.png",
  "main": "./dist/extension.js",
  "activationEvents": [
    "onCommand:openkei.openSidebar",
    "onCommand:openkei.cyclePrimaryAgent",
    "onCommand:openkei.attachExplorerToChat",
    "onView:openkei.chatView"
  ],
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "openkei",
          "title": "OpenKei",
          "icon": "assets/app-icon.png"
        }
      ]
    },
    "views": {
      "openkei": [
        {
          "type": "webview",
          "id": "openkei.chatView",
          "name": "Chat"
        }
      ]
    },
    "commands": [
      {
        "command": "openkei.openSidebar",
        "category": "OpenKei",
        "title": "Open Sidebar",
        "icon": {
          "light": "assets/app-icon.png",
          "dark": "assets/app-icon.png"
        }
      },
      {
        "command": "openkei.focusChat",
        "category": "OpenKei",
        "title": "Focus Chat"
      },
      {
        "command": "openkei.restartApi",
        "category": "OpenKei",
        "title": "Restart API Connection"
      },
      {
        "command": "openkei.showOpenCodeStatus",
        "category": "OpenKei",
        "title": "Show OpenCode Status"
      },
      {
        "command": "openkei.openAgentManager",
        "category": "OpenKei",
        "title": "Open Agent Manager",
        "icon": "$(circuit-board)"
      },
      {
        "command": "openkei.openActiveSessionInEditor",
        "category": "OpenKei",
        "title": "Open Active Session in Editor",
        "icon": "$(link-external)"
      },
      {
        "command": "openkei.openNewSessionInEditor",
        "category": "OpenKei",
        "title": "Open New Session in Editor",
        "icon": {
          "light": "assets/app-icon.png",
          "dark": "assets/app-icon.png"
        }
      },
      {
        "command": "openkei.openCurrentOrNewSessionInEditor",
        "category": "OpenKei",
        "title": "Open Session in Editor",
        "icon": "$(link-external)"
      },
      {
        "command": "openkei.addToContext",
        "category": "OpenKei",
        "title": "Add to Context"
      },
      {
        "command": "openkei.explain",
        "category": "OpenKei",
        "title": "Explain"
      },
      {
        "command": "openkei.improveCode",
        "category": "OpenKei",
        "title": "Improve Code"
      },
      {
        "command": "openkei.newSession",
        "category": "OpenKei",
        "title": "New Session",
        "icon": "$(add)"
      },
      {
        "command": "openkei.showSettings",
        "category": "OpenKei",
        "title": "Settings",
        "icon": "$(settings-gear)"
      },
      {
        "command": "openkei.attachExplorerToChat",
        "category": "OpenKei",
        "title": "Attach to OpenKei Chat"
      },
      {
        "command": "openkei.cyclePrimaryAgent",
        "category": "OpenKei",
        "title": "Cycle Primary Agent"
      }
    ],
    "submenus": [
      {
        "id": "openkei.submenu",
        "label": "OpenKei"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "submenu": "openkei.submenu",
          "group": "navigation"
        }
      ],
      "explorer/context": [
        {
          "command": "openkei.attachExplorerToChat",
          "when": "resourceScheme == file && explorerResourceIsFolder == false",
          "group": "navigation@50"
        }
      ],
      "editor/title": [
        {
          "command": "openkei.openNewSessionInEditor",
          "group": "navigation@1"
        }
      ],
      "view/title": [
        {
          "command": "openkei.newSession",
          "when": "view == openkei.chatView",
          "group": "navigation@1"
        },
        {
          "command": "openkei.openCurrentOrNewSessionInEditor",
          "when": "view == openkei.chatView",
          "group": "navigation@2"
        },
        {
          "command": "openkei.openAgentManager",
          "when": "view == openkei.chatView",
          "group": "navigation@3"
        },
        {
          "command": "openkei.showSettings",
          "when": "view == openkei.chatView",
          "group": "navigation@4"
        }
      ],
      "openkei.submenu": [
        {
          "command": "openkei.explain"
        },
        {
          "command": "openkei.improveCode"
        },
        {
          "command": "openkei.addToContext"
        }
      ]
    },
    "keybindings": [
      {
        "command": "openkei.addToContext",
        "key": "ctrl+l",
        "mac": "cmd+l",
        "when": "editorTextFocus && editorHasSelection"
      },
      {
        "command": "openkei.cyclePrimaryAgent",
        "key": "shift+tab",
        "when": "view.openkei.chatView.visible"
      }
    ],
    "configuration": {
      "title": "OpenKei",
      "properties": {
        "openkei.apiUrl": {
          "type": "string",
          "default": "",
          "description": "URL of an external OpenCode API server. Leave empty to auto-start a local instance."
        },
        "openkei.opencodeBinary": {
          "type": "string",
          "default": "",
          "description": "Optional absolute path to the opencode CLI binary. Useful if PATH lookup fails. Requires window reload or API restart to apply."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "bun run build",
    "build": "bun run build:extension && bun run build:webview",
    "build:extension": "esbuild src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --format=cjs --platform=node --minify --main-fields=module,main",
    "build:webview": "VITE_OPENCODE_URL=/api vite build",
    "dev": "concurrently -n \"ext,web\" -c \"cyan,magenta\" \"bun run watch:extension\" \"bun run dev:webview\"",
    "dev:webview": "vite --host localhost --port 2912 --strictPort",
    "watch:extension": "esbuild src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --format=cjs --platform=node --watch --sourcemap --main-fields=module,main",
    "watch:webview": "vite build --watch",
    "type-check": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.webview.json",
    "lint": "bunx eslint --ext .ts,.tsx src webview",
    "package": "vsce package --no-dependencies"
  },
  "devDependencies": {
    "@types/adm-zip": "^0.5.7",
    "@types/vscode": "^1.85.0",
    "@vitejs/plugin-react": "^5.0.0",
    "@vscode/vsce": "^3.2.1",
    "concurrently": "^9.2.1",
    "esbuild": "^0.24.2",
    "typescript": "~5.8.3",
    "vite": "^7.1.2"
  },
  "dependencies": {
    "@openchamber/ui": "workspace:*",
    "@opencode-ai/sdk": "^1.4.25",
    "adm-zip": "^0.5.16",
    "jsonc-parser": "^3.3.1",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "yaml": "^2.8.1"
  }
}
